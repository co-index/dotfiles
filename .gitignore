.DS_Store
work/

# Never commit local Claude Code secrets or runtime state. These patterns
# exist in case ~/.claude or ~/.claude.json content is ever copied into the
# repo by accident; they match at any depth.
.claude.json
.credentials.json
credentials.json
sessions/
projects/
cache/
telemetry/
daemon*
*.log
*.status.json
*.tmp

# Local backups generated by the installers.
*.bak
*.backup
*.bak.*
